// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Speciality {
  id        String   @id @default(uuid())
  name      String   @unique
  doctors   Doctor[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Papéis permitidos no sistema RBAC (Role-Based Access Control)
enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

// Tabela global de Utilizadores
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(PATIENT) // Por padrão, novos cadastros são pacientes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relações opostas que o Prisma precisa para mapear o banco
  doctorProfile Doctor? // Um utilizador PODE ter um perfil de médico (1:1)
  appointments Appointment[]
}

// Tabela com dados exclusivos para Médicos
model Doctor {
  id           String     @id @default(uuid())
  licenseId    String     @unique // Cédula profissional -> CRM

  // 1:1 com tabela User
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // N:1 Muito médicos pertencem a uma especialidade
  specialityId String
  speciality   Speciality @relation(fields: [specialityId], references: [id])

  slots AvailabilitySlot[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Tabela para gerir os horários livres dos médicos
model AvailabilitySlot {
  id        String   @id @default(uuid())
  dateTime  DateTime 
  isBooked  Boolean  @default(false) 
  
  // ´N:1 Relacionamento com o médico tem muitos slots
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  // Relacionamento opcional com um Agendamento (Um slot ocupado gera 1 agendamento)
  appointment Appointment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabela para registar as Consultas Agendadas
model Appointment {
  id                 String           @id @default(uuid())
  status             String           @default("SCHEDULED") // SCHEDULED, CANCELLED
  cancellationReason String?          

  patientId          String
  patient            User             @relation(fields: [patientId], references: [id])

  // 1:1 slot e availabilitySlot
  slotId             String           @unique
  slot               AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}
